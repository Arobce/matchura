# PostgreSQL
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=postgres

# JWT
JWT_SECRET=generate-a-secure-random-secret-at-least-32-chars
JWT_ISSUER=matchura
JWT_AUDIENCE=matchura-clients

# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Redis
REDIS_CONNECTION=redis:6379

# AWS S3 (resume storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

# RabbitMQ
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASS=your_rabbitmq_password

# pgAdmin (optional, local dev only)
PGADMIN_EMAIL=admin@matchura.dev
PGADMIN_PASSWORD=admin

# Email (SendLayer)
SENDLAYER_API_KEY=your_sendlayer_api_key
SENDLAYER_FROM_EMAIL=your_email@example.com

# Sentry (optional)
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
SENTRY_AUTH_TOKEN=
