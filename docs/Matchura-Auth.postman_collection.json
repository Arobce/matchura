{
  "info": {
    "name": "Matchura Auth API",
    "_postman_id": "matchura-auth-001",
    "description": "Authentication endpoints for the Matchura job matching platform. Handles registration, login, email verification, and two-factor authentication.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5001" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Register - Candidate",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var json = pm.response.json();",
              "    pm.test('Requires email verification', function() { pm.expect(json.requiresEmailVerification).to.be.true; });",
              "    pm.test('No token before verification', function() { pm.expect(json.token).to.be.null; });",
              "    pm.test('Role is Candidate', function() { pm.expect(json.role).to.eql('Candidate'); });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"candidate@test.com\",\n  \"password\": \"TestPass1\",\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"role\": \"Candidate\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "register"]
        },
        "description": "Register a new candidate. A 6-digit verification code will be emailed to the address provided."
      }
    },
    {
      "name": "Register - Employer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var json = pm.response.json();",
              "    pm.test('Requires email verification', function() { pm.expect(json.requiresEmailVerification).to.be.true; });",
              "    pm.test('Role is Employer', function() { pm.expect(json.role).to.eql('Employer'); });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"employer@test.com\",\n  \"password\": \"TestPass1\",\n  \"firstName\": \"Acme\",\n  \"lastName\": \"HR\",\n  \"role\": \"Employer\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "register"]
        }
      }
    },
    {
      "name": "Register - Admin (should fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Rejects Admin role', function() { pm.response.to.have.status(400); });"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"TestPass1\",\n  \"firstName\": \"Admin\",\n  \"lastName\": \"User\",\n  \"role\": \"Admin\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "register"]
        }
      }
    },
    {
      "name": "Register - Weak Password (should fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Rejects weak password', function() { pm.response.to.have.status(400); });"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"weak@test.com\",\n  \"password\": \"123\",\n  \"firstName\": \"Weak\",\n  \"lastName\": \"Password\",\n  \"role\": \"Candidate\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "register"]
        }
      }
    },
    {
      "name": "Register - Duplicate Email (should fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Rejects duplicate email', function() { pm.response.to.have.status(409); });"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"candidate@test.com\",\n  \"password\": \"TestPass1\",\n  \"firstName\": \"Duplicate\",\n  \"lastName\": \"User\",\n  \"role\": \"Candidate\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/register",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "register"]
        }
      }
    },
    {
      "name": "Verify Email",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var json = pm.response.json();",
              "    pm.collectionVariables.set('token', json.token);",
              "    pm.test('Has token after verification', function() { pm.expect(json.token).to.be.a('string'); });",
              "    pm.test('Email verified', function() { pm.expect(json.requiresEmailVerification).to.be.false; });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"candidate@test.com\",\n  \"code\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/verify-email",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "verify-email"]
        },
        "description": "Replace the code with the actual 6-digit code from the verification email."
      }
    },
    {
      "name": "Resend Verification Code",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Returns 204', function() { pm.response.to.have.status(204); });"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"candidate@test.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/resend-verification",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "resend-verification"]
        }
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var json = pm.response.json();",
              "    if (json.token) {",
              "        pm.collectionVariables.set('token', json.token);",
              "        pm.test('Has token', function() { pm.expect(json.token).to.be.a('string'); });",
              "    }",
              "    if (json.requiresTwoFactor) {",
              "        pm.test('2FA required', function() { pm.expect(json.requiresTwoFactor).to.be.true; });",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"candidate@test.com\",\n  \"password\": \"TestPass1\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Login - Wrong Password (should fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Returns 401', function() { pm.response.to.have.status(401); });"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"candidate@test.com\",\n  \"password\": \"WrongPassword1\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Login - Nonexistent User (should fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Returns 401', function() { pm.response.to.have.status(401); });"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"nobody@test.com\",\n  \"password\": \"TestPass1\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Get Current User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns user info', function() {",
              "    pm.response.to.have.status(200);",
              "    var json = pm.response.json();",
              "    pm.expect(json.email).to.be.a('string');",
              "    pm.expect(json.role).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{base_url}}/api/auth/me",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "me"]
        }
      }
    },
    {
      "name": "Get Current User - No Token (should fail)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Returns 401', function() { pm.response.to.have.status(401); });"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/auth/me",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "me"]
        }
      }
    },
    {
      "name": "Enable 2FA",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Returns 204', function() { pm.response.to.have.status(204); });"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"enable\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/2fa/toggle",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "2fa", "toggle"]
        }
      }
    },
    {
      "name": "Disable 2FA",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": ["pm.test('Returns 204', function() { pm.response.to.have.status(204); });"],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"enable\": false\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/2fa/toggle",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "2fa", "toggle"]
        }
      }
    },
    {
      "name": "Verify 2FA Code",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var json = pm.response.json();",
              "    pm.collectionVariables.set('token', json.token);",
              "    pm.test('Has token after 2FA', function() { pm.expect(json.token).to.be.a('string'); });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"candidate@test.com\",\n  \"code\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/auth/verify-2fa",
          "host": ["{{base_url}}"],
          "path": ["api", "auth", "verify-2fa"]
        },
        "description": "Replace the code with the actual 6-digit code from your email or service logs."
      }
    }
  ]
}
