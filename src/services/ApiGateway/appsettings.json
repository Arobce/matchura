{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "RateLimiterPolicy": "anonymous"
      },
      "profiles-route": {
        "ClusterId": "profile-cluster",
        "Match": { "Path": "/api/profiles/{**catch-all}" },
        "RateLimiterPolicy": "authenticated"
      },
      "jobs-route": {
        "ClusterId": "job-cluster",
        "Match": { "Path": "/api/jobs/{**catch-all}" },
        "RateLimiterPolicy": "authenticated"
      },
      "skills-route": {
        "ClusterId": "job-cluster",
        "Match": { "Path": "/api/skills/{**catch-all}" },
        "RateLimiterPolicy": "authenticated"
      },
      "applications-route": {
        "ClusterId": "application-cluster",
        "Match": { "Path": "/api/applications/{**catch-all}" },
        "RateLimiterPolicy": "authenticated"
      },
      "resumes-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/resumes/{**catch-all}" },
        "RateLimiterPolicy": "authenticated"
      },
      "documents-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/documents/{**catch-all}" },
        "RateLimiterPolicy": "authenticated"
      },
      "matching-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/matching/{**catch-all}" },
        "RateLimiterPolicy": "ai"
      },
      "skillgap-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/skillgap/{**catch-all}" },
        "RateLimiterPolicy": "ai"
      },
      "analytics-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/analytics/{**catch-all}" },
        "RateLimiterPolicy": "authenticated"
      },
      "ai-ping-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/ai/{**catch-all}" },
        "RateLimiterPolicy": "anonymous"
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": { "Address": "http://auth-service:8080" }
        }
      },
      "profile-cluster": {
        "Destinations": {
          "profile-service": { "Address": "http://profile-service:8080" }
        }
      },
      "job-cluster": {
        "Destinations": {
          "job-service": { "Address": "http://job-service:8080" }
        }
      },
      "application-cluster": {
        "Destinations": {
          "application-service": { "Address": "http://application-service:8080" }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "ai-service": { "Address": "http://ai-service:8080" }
        }
      }
    }
  }
}
